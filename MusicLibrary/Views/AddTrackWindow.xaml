<Window x:Class="MusicLibrary.Views.AddTrackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить трек"
        Icon="Assets/Brand/musicbakh.ico"
        Width="560"
        Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="{StaticResource BodyFont}"
        Background="{StaticResource BackgroundBrush}">
    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Добавить трек" FontFamily="{StaticResource HeadingFont}" Foreground="{StaticResource PrimaryBrush}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
                <Button Content="Из файла" Command="{Binding SwitchToFileCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="160" Margin="0,0,8,0">
                    <Button.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLocalFileMode}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource GoldGradientBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource BackgroundBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="По ссылке" Command="{Binding SwitchToUrlCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="160">
                    <Button.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUrlMode}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource GoldGradientBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource BackgroundBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,0,0,14">
                <StackPanel Visibility="{Binding IsLocalFileMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Локальный файл (.mp3 / .wav)" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,6" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Обзор..." Command="{Binding BrowseFileCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="120" Margin="8,0,0,0" Height="40" />
                        <TextBox Text="{Binding LocalFilePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Background="{StaticResource SecondaryBrush}" Foreground="{StaticResource ForegroundBrush}" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" Padding="10,8" VerticalContentAlignment="Center" />
                    </DockPanel>
                </StackPanel>
                <StackPanel Visibility="{Binding IsUrlMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Прямая ссылка на mp3/wav" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,6" />
                    <TextBox Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource SecondaryBrush}" Foreground="{StaticResource ForegroundBrush}" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" Padding="10,8" VerticalContentAlignment="Center" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="3">
                <StackPanel Visibility="{Binding HasCandidate, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DockPanel Margin="0,0,0,16">
                        <Border DockPanel.Dock="Left" Width="120" Height="120" CornerRadius="12" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" Margin="0,0,16,0">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding CoverPreview}" Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Название" Foreground="{StaticResource MutedForegroundBrush}" FontSize="12" />
                            <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource SecondaryBrush}" Foreground="{StaticResource ForegroundBrush}" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" Padding="8,6" Margin="0,2,0,8" />
                            <TextBlock Text="Исполнитель" Foreground="{StaticResource MutedForegroundBrush}" FontSize="12" />
                            <TextBox Text="{Binding EditArtist, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource SecondaryBrush}" Foreground="{StaticResource ForegroundBrush}" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" Padding="8,6" Margin="0,2,0,8" />
                            <TextBlock Text="Жанр" Foreground="{StaticResource MutedForegroundBrush}" FontSize="12" />
                            <TextBox Text="{Binding EditGenre, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource SecondaryBrush}" Foreground="{StaticResource ForegroundBrush}" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" Padding="8,6" Margin="0,2,0,0" />
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="4" Margin="0,12,0,0">
                <ProgressBar Visibility="{Binding IsImporting, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Minimum="0" Maximum="1" Value="{Binding ProgressValue, Mode=OneWay}" Height="6" Foreground="{StaticResource PrimaryBrush}" Background="{StaticResource AccentBrush}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusKind, Converter={StaticResource StatusKindToBrushConverter}}" TextWrapping="Wrap" Margin="0,0,0,12" />
            </StackPanel>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="120" Margin="0,0,8,0" />
                <Button Content="Импортировать" Command="{Binding StartImportCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="160" Margin="0,0,8,0" />
                <Button Content="Сохранить" Command="{Binding ConfirmCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="160" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
