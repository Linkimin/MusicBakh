<Window x:Class="MusicLibrary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MusicBakh"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        FontFamily="{StaticResource BodyFont}"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="106" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource CardOverlayBrush}" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="0,0,0,1" Padding="28,18">
            <DockPanel VerticalAlignment="Center">
                <Button DockPanel.Dock="Right" Content="＋ Добавить трек" Command="{Binding AddTrackCommand}" Style="{StaticResource SecondaryButtonStyle}" Height="42" Padding="18,0" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="54" Height="54" CornerRadius="12" Background="{StaticResource GoldGradientBrush}">
                        <Grid>
                            <TextBlock Text="MB" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BackgroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <Polyline Points="12,38 18,32 24,36 30,26 36,34 42,30"
                                      Stroke="{StaticResource BackgroundBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      VerticalAlignment="Bottom"
                                      Margin="0,0,0,8" />
                        </Grid>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="MusicBakh" FontFamily="{StaticResource HeadingFont}" Foreground="{StaticResource PrimaryBrush}" FontSize="28" FontWeight="SemiBold" />
                        <TextBlock Text="Музыкальная библиотека" Foreground="{StaticResource MutedForegroundBrush}" FontSize="13" Margin="1,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="45*" />
                <ColumnDefinition Width="30*" />
                <ColumnDefinition Width="25*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#4D16161F" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="24">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                        <TextBlock Text="Фильтр по жанру" Foreground="{StaticResource ForegroundBrush}" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,10" />
                        <ComboBox ItemsSource="{Binding Genres}"
                                  SelectedItem="{Binding SelectedGenre, Mode=TwoWay}"
                                  Style="{StaticResource GenreComboBoxStyle}" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding DisplayedTracks}"
                             SelectedItem="{Binding SelectedTrack, Mode=TwoWay}"
                             ItemTemplate="{StaticResource TrackCardTemplate}"
                             ItemContainerStyle="{StaticResource TrackListBoxItemStyle}"
                             Style="{StaticResource PanelListBoxStyle}" />
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#3316161F" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="0,0,1,0" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="176" Height="176" CornerRadius="16" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2" HorizontalAlignment="Center">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding SelectedTrack.CoverPath}" Stretch="UniformToFill" />
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#D4A574" BlurRadius="35" ShadowDepth="0" Opacity="0.22" />
                            </Border.Effect>
                        </Border>

                        <TextBlock Text="{Binding SelectedTrack.Title, TargetNullValue='Выберите трек'}" Foreground="{StaticResource ForegroundBrush}" FontSize="21" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" Margin="0,20,0,6" />
                        <TextBlock Text="{Binding SelectedTrack.Artist}" Foreground="{StaticResource MutedForegroundBrush}" FontSize="15" TextAlignment="Center" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,18">
                            <Border Background="#1AD4A574" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12,5">
                                <TextBlock Text="{Binding SelectedTrack.Genre}" Foreground="{StaticResource PrimaryBrush}" />
                            </Border>
                            <TextBlock Text="{Binding SelectedTrack.DurationText}" Foreground="{StaticResource MutedForegroundBrush}" Margin="12,5,0,0" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsSelectedPlaying, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ProgressBar Minimum="0" Maximum="{Binding ProgressMaximum, Mode=OneWay}" Value="{Binding ProgressValue, Mode=OneWay}" Height="8" Foreground="{StaticResource PrimaryBrush}" Background="{StaticResource AccentBrush}" Margin="0,0,0,8" />
                            <DockPanel Margin="0,0,0,18">
                                <TextBlock Text="{Binding CurrentPositionText}" Foreground="{StaticResource MutedForegroundBrush}" DockPanel.Dock="Left" />
                                <TextBlock Text="{Binding CurrentDurationText}" Foreground="{StaticResource MutedForegroundBrush}" HorizontalAlignment="Right" />
                            </DockPanel>
                        </StackPanel>

                        <Border Visibility="{Binding ShowOtherPlayingBadge, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="#1AD4A574" BorderBrush="{StaticResource GoldBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12,8" Margin="0,0,0,18">
                            <TextBlock Text="{Binding OtherPlayingText}" Foreground="{StaticResource PrimaryBrush}" FontSize="13" TextTrimming="CharacterEllipsis" />
                        </Border>

                        <Button Content="{Binding PlayPauseText}" Command="{Binding PlayPauseCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,10" />
                        <Button Content="Стоп" Command="{Binding StopCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10" />
                        <Button Content="Сохранить" Command="{Binding SaveTrackCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10" />
                        <Button Content="Удалить трек" Command="{Binding DeleteTrackCommand}" Style="{StaticResource SecondaryButtonStyle}" Foreground="{StaticResource ErrorBrush}" Visibility="{Binding CanDeleteSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{Binding StatusKind, Converter={StaticResource StatusKindToBrushConverter}}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,18,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="#4D16161F" Padding="24">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="История прослушиваний" Foreground="{StaticResource ForegroundBrush}" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,18" />
                    <ListBox ItemsSource="{Binding PlaybackHistory}"
                             ItemTemplate="{StaticResource HistoryItemTemplate}"
                             Style="{StaticResource PanelListBoxStyle}" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
