<Window x:Class="MusicLibrary.Views.ConfirmationDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подтверждение"
        Icon="pack://application:,,,/Assets/Brand/musicbakh.ico"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="{StaticResource BodyFont}"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <Style x:Key="DialogDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
            <Setter Property="Foreground" Value="{StaticResource BackgroundBrush}" />
            <Setter Property="Width" Value="136" />
            <Setter Property="Height" Value="48" />
        </Style>

        <Style x:Key="DialogCancelButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="128" />
            <Setter Property="Height" Value="48" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource GoldBorderBrush}"
            BorderThickness="1"
            Padding="26">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,24">
                <Border DockPanel.Dock="Left"
                        Width="46"
                        Height="46"
                        CornerRadius="12"
                        Background="#22E06C75"
                        BorderBrush="#66E06C75"
                        BorderThickness="1"
                        Margin="0,0,14,0">
                    <TextBlock Text="!"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource ErrorBrush}"
                               FontSize="28"
                               FontWeight="Bold" />
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               FontFamily="{StaticResource HeadingFont}"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Действие нельзя отменить"
                               Foreground="{StaticResource MutedForegroundBrush}"
                               FontSize="12"
                               Margin="0,3,0,0" />
                </StackPanel>
            </DockPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,2,0,0">
                <TextBlock Text="Трек"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           FontSize="12"
                           Margin="0,0,0,6" />
                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource GoldBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,15">
                    <TextBlock x:Name="TrackNameText"
                               Foreground="{StaticResource ForegroundBrush}"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               LineHeight="22" />
                </Border>
                <TextBlock x:Name="MessageText"
                           Foreground="{StaticResource MutedForegroundBrush}"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           Margin="0,10,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,22,0,0">
                <Button Content="Отмена"
                        IsCancel="True"
                        Click="OnCancelClick"
                        Style="{StaticResource DialogCancelButtonStyle}"
                        Margin="0,0,10,0" />
                <Button Content="Удалить"
                        IsDefault="True"
                        Click="OnConfirmClick"
                        Style="{StaticResource DialogDangerButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
