<Application x:Class="MusicLibrary.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MusicLibrary.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml" />
                <ResourceDictionary Source="Resources/Brushes.xaml" />
                <ResourceDictionary Source="Resources/ButtonStyles.xaml" />
                <ResourceDictionary Source="Resources/ComboBoxStyles.xaml" />
                <ResourceDictionary Source="Resources/ListStyles.xaml" />
                <ResourceDictionary Source="Resources/TrackTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="HeadingFont">Playfair Display, Georgia</FontFamily>
            <FontFamily x:Key="BodyFont">Montserrat, Segoe UI</FontFamily>

            <converters:StatusKindToBrushConverter x:Key="StatusKindToBrushConverter"
                                                   InfoBrush="{StaticResource MutedForegroundBrush}"
                                                   SuccessBrush="{StaticResource SuccessBrush}"
                                                   ErrorBrush="{StaticResource ErrorBrush}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
